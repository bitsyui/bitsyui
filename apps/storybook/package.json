{
  "name": "@bitsyui/storybook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@bitsyui/styles": "workspace:*",
    "@bitsyui/ui-solid": "workspace:*"
  },
  "devDependencies": {
    "solid-js": "^1.9.0",
    "storybook": "^10.0.11",
    "storybook-solidjs-vite": "^10.0.11"
  },
  "scripts": {
    "build": "CI=1 STORYBOOK_DISABLE_TELEMETRY=1 HOME=/tmp/bitsyui-storybook-home storybook build",
    "storybook": "STORYBOOK_DISABLE_TELEMETRY=1 HOME=/tmp/bitsyui-storybook-home storybook dev -p 6006",
    "lint": "CI=1 STORYBOOK_DISABLE_TELEMETRY=1 HOME=/tmp/bitsyui-storybook-home storybook build --test --output-dir /tmp/bitsyui-storybook-test",
    "test": "echo \"no storybook tests yet\"",
    "format": "prettier --check ."
  }
}
